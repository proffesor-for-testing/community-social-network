# =============================================================================
# Test Environment Configuration
# =============================================================================

NODE_ENV=test
PORT=3001

# Database (separate test database)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=csn_test

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (deterministic test secrets)
JWT_SECRET=test-jwt-secret-for-testing-only
JWT_REFRESH_SECRET=test-refresh-secret-for-testing-only
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200

# File storage (mock in tests)
S3_BUCKET=csn-uploads-test
S3_REGION=us-east-1
S3_ACCESS_KEY=test-access-key
S3_SECRET_KEY=test-secret-key

# Email (mock in tests)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@csn.test
SMTP_SECURE=false

# Logging (minimal in tests)
LOG_LEVEL=warn
