# ============================================================================
# Community Social Network - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values for your environment
# NEVER commit .env file to version control!
# ============================================================================

# Application Settings
# ============================================================================
NODE_ENV=development
PORT=3000
HOST=localhost
API_VERSION=v1

# Database Configuration (PostgreSQL)
# ============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/community_social_network?schema=public"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# Redis Configuration
# ============================================================================
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_MAX_RETRIES=3

# JWT Authentication
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ALGORITHM=HS256

# Password Hashing
# ============================================================================
BCRYPT_ROUNDS=12

# Session Configuration
# ============================================================================
SESSION_MAX_AGE=86400000
SESSION_SECURE=false
SESSION_SAME_SITE=lax

# Rate Limiting
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL=false

# File Upload Configuration
# ============================================================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp
UPLOAD_DIRECTORY=uploads

# Image Processing (Sharp)
# ============================================================================
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080
IMAGE_QUALITY=80
THUMBNAIL_WIDTH=150
THUMBNAIL_HEIGHT=150

# CORS Configuration
# ============================================================================
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Logging Configuration
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=combined
LOG_FILE_PATH=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7

# WebSocket Configuration
# ============================================================================
WS_PATH=/socket.io
WS_CORS_ORIGIN=http://localhost:3000
WS_PING_TIMEOUT=60000
WS_PING_INTERVAL=25000

# Queue Configuration (Bull)
# ============================================================================
QUEUE_PREFIX=csn
QUEUE_RETRY_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=1000

# Email Configuration (SMTP)
# ============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Community Social Network
SMTP_FROM_EMAIL=noreply@example.com

# External Services
# ============================================================================
# AWS S3 (for file storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Monitoring & Analytics
# ============================================================================
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=
ANALYTICS_ENABLED=false

# Feature Flags
# ============================================================================
FEATURE_GROUPS_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true
FEATURE_MEDIA_UPLOAD_ENABLED=true
FEATURE_WEBSOCKET_ENABLED=true

# Security
# ============================================================================
HELMET_ENABLED=true
TRUST_PROXY=false
SECURE_COOKIES=false

# Development Settings
# ============================================================================
DEBUG=false
ENABLE_SWAGGER=true
ENABLE_PLAYGROUND=true
