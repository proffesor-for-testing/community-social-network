# =============================================================================
# Community Social Network - Environment Variables
# =============================================================================
# Copy this file to .env and fill in appropriate values.
# NEVER commit .env files with real secrets to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
API_PORT=3000
WEB_PORT=4200

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:5173

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=csn_dev

# Composed DATABASE_URL (used by some tools like TypeORM CLI)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/csn_dev

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Composed REDIS_URL (alternative to individual vars)
# REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
# IMPORTANT: Generate strong secrets for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ---------------------------------------------------------------------------
# S3 / File Storage
# ---------------------------------------------------------------------------
S3_BUCKET=csn-uploads-dev
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ---------------------------------------------------------------------------
# Email / SMTP
# ---------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@csn.local
SMTP_SECURE=false

# ---------------------------------------------------------------------------
# Docker Compose Ports (host-side overrides)
# ---------------------------------------------------------------------------
POSTGRES_PORT=5432
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=debug
